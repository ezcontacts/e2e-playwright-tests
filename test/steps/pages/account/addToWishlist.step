import { ADMIN } from "../../../data-test/testData";
import { Given, Then, When } from "../../../fixtures/fixture";
import { DataTable } from "playwright-bdd";


Given('the user is on the "Wish List" page', async ({ addToWishListPage }) => {
  await addToWishListPage.open();
});

//Started -> Navigation to Wish List Page
Then("the page should display the heading {string}", async ({ addToWishListPage }, text: string) => {
  await addToWishListPage.verifyTitleHaveText(text);
});

Then("the page URL should contain {string}", async ({ addToWishListPage }, text: string) => {
   await addToWishListPage.verifyUrlContains(text);
});
// Completed -> # Navigation to Wish List Page

Then('the page should display a message {string}',async ({ addToWishListPage }, message: string) => {
    await addToWishListPage.verifyMessageVisible(message);
});

Then('the following links should be visible:',async ({ addToWishListPage }, dataTable: DataTable) => {
    const links = dataTable.raw().flat();
    await addToWishListPage.verifyMultipleLinksVisible(links);
});
// Completed -> # When the wishlist is empty.

//Started -> Add to Cart link is present and Navigate to Cart page.
Given("the {string} has at least one product", async ({ addToWishListPage }) => {
  await addToWishListPage.ensureProductExistsInWishList();
});

When('the user clicks the "Add to Cart" link for the product', async ({ addToWishListPage }) => {
  await addToWishListPage.clickAddToCartForFirstProduct();
});

Then("the product should be added to the cart", async ({ addToWishListPage }) => {
  await addToWishListPage.verifyProductAddedToCart();
});

Then("the user should be redirected to the Cart page", async ({ addToWishListPage }) => {
  await addToWishListPage.verifyRedirectedToCartPage();
});
//Completed -> Add to Cart link is present and Navigate to Cart page.


When('the user clicks the "Remove" link for a product', async ({ addToWishListPage }) => {
  await addToWishListPage.clickRemoveLinkForFirstProduct();
});

Then('a confirmation popup should be displayed with the message {string}', async ({ addToWishListPage }, message: string) => {
  await addToWishListPage.verifyRemoveConfirmationPopup(message);
});

When('the user clicks "Remove" button on the confirmation popup', async ({ addToWishListPage }) => {
  await addToWishListPage.confirmRemoveProduct();
});

Then('the page should display the message {string}', async ({ addToWishListPage }, message: string) => {
  await addToWishListPage.verifyMessageVisible(message);
});
